# PatientPunk / agentic-health-hackathon — example environment file.
# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.
#
# Load it when starting the API, e.g.:
#   uvicorn backend.search_api.app:app --host 127.0.0.1 --port 8000 --env-file .env
# (uvicorn reads --env-file natively; no extra dependency needed.)

# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------
# Absolute path to the SQLite corpus the API serves. Defaults to ./patientpunk.db.
PATIENTPUNK_DB=C:/Users/scgee/OneDrive/Documents/Projects/agentic-health-hackathon/patientpunk.db

# ---------------------------------------------------------------------------
# LLM (powers "Why might this help?" explanations + the literature AI summary)
# Without a key these features fall back to deterministic text — no errors.
# Uses OpenRouter's chat-completions API.
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
# Alias accepted if you prefer: LLM_API_KEY=
LLM_API_KEY=
# Model id (OpenRouter). Default: deepseek/deepseek-chat
LLM_MODEL=deepseek/deepseek-chat

# ---------------------------------------------------------------------------
# Literature search (PubMed / Europe PMC / OpenAlex / Crossref)
# ---------------------------------------------------------------------------
# NCBI E-utilities API key — raises PubMed's rate limit from 3 to 10 requests/sec.
# Get one free at https://www.ncbi.nlm.nih.gov/account/ (Settings -> API Key Management).
NCBI_API_KEY=
# Alias accepted: PUBMED_API_KEY=
PUBMED_API_KEY=

# Contact emails sent to the scholarly APIs (politeness; improves rate-limit standing).
PUBMED_EMAIL=
OPENALEX_EMAIL=
CROSSREF_MAILTO=

# ---------------------------------------------------------------------------
# Literature search tuning (optional — sensible defaults if unset)
# ---------------------------------------------------------------------------
# AHH_CACHE_DIR=                 # where API responses are disk-cached
# AHH_HTTP_TIMEOUT_SECONDS=20.0
# AHH_DEFAULT_MAX_RESULTS=12
# AHH_DEFAULT_START_YEAR=2000
